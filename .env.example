# ─── Base de datos ────────────────────────────────────────────────────────────
# Cadena de conexión PostgreSQL.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/satem_food_engine?schema=public"

# ─── Aplicación ───────────────────────────────────────────────────────────────
# URL pública de la aplicación (sin trailing slash).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Entorno de ejecución (development | staging | production)
NODE_ENV="development"

# ─── n8n ──────────────────────────────────────────────────────────────────────
# URL base de la instancia de n8n.
N8N_BASE_URL="http://localhost:5678"

# API Key de n8n (configurar en n8n → Settings → API).
N8N_API_KEY=""

# Webhook URLs para disparar workflows desde Next.js.
N8N_WEBHOOK_ORDER_COMANDA=""
N8N_WEBHOOK_LOW_STOCK_ALERT=""
N8N_WEBHOOK_PAYMENT_CONFIRMATION=""

# ─── Pagos ────────────────────────────────────────────────────────────────────
# Stripe (o pasarela de pago seleccionada)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ─── IA / Chatbot ─────────────────────────────────────────────────────────────
# OpenAI
# OPENAI_API_KEY=""
# OPENAI_MODEL="gpt-4o-mini"

# Google Gemini (alternativa)
# GOOGLE_GENERATIVE_AI_API_KEY=""

# ─── Google APIs ──────────────────────────────────────────────────────────────
# GOOGLE_MAPS_API_KEY=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ─── Almacenamiento (futuro) ──────────────────────────────────────────────────
# Bucket S3-compatible para imágenes de productos.
# STORAGE_BUCKET=""
# STORAGE_REGION=""
# STORAGE_ACCESS_KEY_ID=""
# STORAGE_SECRET_ACCESS_KEY=""
# NEXT_PUBLIC_STORAGE_PUBLIC_URL=""

# ─── Seguridad ────────────────────────────────────────────────────────────────
# Secret para firmar tokens internos (mínimo 32 caracteres).
# AUTH_SECRET=""
