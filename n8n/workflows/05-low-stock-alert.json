          }
        ]
      ]
    },
    "Normalize Alert Payload": {
      "main": [
        [
          {
            "node": "Is Critical? (Stock < 50% Threshold)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Is Critical? (Stock < 50% Threshold)": {
      "main": [
        [
          {
            "node": "Mark as Critical Alert",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Mark as Warning Alert",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Mark as Critical Alert": {
      "main": [
        [
          {
