# Normalize line endings: LF in the repository, CRLF in working copies on Windows.
* text=auto eol=lf

# Binary files — no normalization
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary
